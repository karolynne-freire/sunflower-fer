{
  "expo": {
    "name": "Sunflower",
    "slug": "sunflower-app",
    "version": "1.0.0",
    "scheme": "sunflower",
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "O Sunflower precisa da câmera para reconhecer emoções."
        }
      ],
      "react-native-fast-tflite",
      "expo-router"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF9E6"
      },
      "package": "com.sunflower.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.sunflower.app"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65e717d7-0281-4ead-aa66-f1c94fa56bee"
      }
    }
  }
}
