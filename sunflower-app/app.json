{
  "expo": {
    "name": "Sunflower",
    "slug": "sunflower-app",
    "version": "1.0.0",
    "scheme": "sunflower",
    "platforms": ["ios", "android"],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "O Sunflower precisa da câmera para reconhecer emoções."
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF9E6"
      },
      "package": "com.sunflower.app"
    },
    "ios": {
      "bundleIdentifier": "com.sunflower.app"
    }
  }
}
